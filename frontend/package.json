{
  "name": "daedalus-ui",
  "version": "0.0.1",
  "description": "Claude Code-style terminal UI for the Daedalus computer control agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "daedalus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.4.0",
    "cli-highlight": "^2.1.11",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.0",
    "terminal-image": "^4.3.0",
    "yaml": "^2.7.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
